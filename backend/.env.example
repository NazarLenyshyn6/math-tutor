# =============================================================================
# LLM — NVIDIA NIM
# API key and model for the main language model used to generate tutoring
# responses and perform internal routing/rewriting tasks.
#
# Get your API key at: https://build.nvidia.com
# Browse available models at: https://build.nvidia.com/explore/discover
# Example model: meta/llama-3.1-70b-instruct
# =============================================================================
NVIDIA_API_KEY=
LLM_MODEL_NAME=

# =============================================================================
# Embeddings — HuggingFace Inference Endpoints
# API token and model used to generate dense vector embeddings for semantic
# search (stored in ChromaDB).
#
# Get your token at: https://huggingface.co/settings/tokens
# Recommended model: sentence-transformers/all-MiniLM-L6-v2
# =============================================================================
HF_API_TOKEN=
EMBEDDING_MODEL_NAME=

# =============================================================================
# Elasticsearch
# URL of the running Elasticsearch instance used for lexical (BM25) search.
# When running with Docker Compose this is typically http://elasticsearch:9200.
# For a local dev setup use http://localhost:9200.
# =============================================================================
ELASTICSEARCH_URL=

# =============================================================================
# Storage
# Root directory where the app persists all data:
#   - Rendered PDF page images  (.store/documents/)
#   - ChromaDB vector collections  (.store/semantics/)
#   - Elasticsearch index registry  (.store/lexical/)
#   - Conversation session files  (.store/conversation_memory/)
#   - Document registries  (.store/collections_registry.json, etc.)
#
# Use a relative path (e.g. .store) or an absolute path.
# When running with Docker Compose use /app/.store (maps inside the container).
# For a local dev setup use a relative path such as .store.
# The directory is created automatically if it does not exist.
# =============================================================================
STORAGE_ROOT_PATH=
